{
  "scopeName": "source.janet",
  "name": "Janet",
  "patterns": [
    {
      "name": "comment.line.semicolon.janet",
      "begin": "#",
      "end": "$"
    },
    {
      "name": "string.quoted.double.janet",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.janet",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "constant.numeric.janet",
      "match": "\\b(?:[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?|0[xX][0-9a-fA-F]+)\\b"
    },
    {
      "name": "keyword.control.janet",
      "match": "\\b(?:def|defn|defn-|defmacro|var|let|do|if|when|unless|cond|case|for|each|while|break|return|try|catch|protect|with|as|set|put|get|length|in|not|and|or|match|import|use|require|:=|:|\\.)\\b"
    },
    {
      "name": "keyword.other.janet",
      "match": "\\b(?::[a-zA-Z_][a-zA-Z0-9_-]*)\\b"
    },
    {
      "name": "support.function.builtin.janet",
      "match": "\\b(?:print|println|string|buffer|tuple|array|table|struct|number|integer|boolean|symbol|keyword|string/format|string/join|string/split|math/|array/|table/|os/|io/|net/|peg/|fiber/|debug/)\\b"
    }
  ]
}
